<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Part_Co" name="Компания X" processRef="Proc_Co" />
    <bpmn:participant id="Part_Sup" name="Поставщик" processRef="Proc_Sup" />
    <bpmn:messageFlow id="mf1" name="Заявка на закупку (почта)" sourceRef="Task_Order" targetRef="Start_Ord" />
    <bpmn:messageFlow id="mf2" name="Поставка оборудования" sourceRef="Task_SupDel" targetRef="Event_0944k2j" />
    <bpmn:textAnnotation id="An1">
      <bpmn:text>? Системы №1 ↔ №2: интеграция или двойной ручной ввод?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="An1_as" associationDirection="None" sourceRef="An1" targetRef="f3" />
    <bpmn:textAnnotation id="An2">
      <bpmn:text>? Нет шага согласования / авторизации (право, бюджет)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="An2_as" associationDirection="None" sourceRef="An2" targetRef="Task_Accept" />
    <bpmn:textAnnotation id="An3">
      <bpmn:text>? Частичное наличие не обработано («всё или ничего»)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="An3_as" associationDirection="None" sourceRef="An3" targetRef="GW_Avail" />
    <bpmn:textAnnotation id="An4">
      <bpmn:text>? Поставщик: не обработаны задержка / срыв / не тот товар</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="An4_as" associationDirection="None" sourceRef="An4" targetRef="Task_SupDel" />
    <bpmn:textAnnotation id="An5">
      <bpmn:text>? Заявки закрыты до подтверждения получения</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="An5_as" associationDirection="None" sourceRef="An5" targetRef="Task_Issue" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_Co" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_user" name="Пользователь">
        <bpmn:flowNodeRef>Task_Create</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Recv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Rate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_User</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_Need</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_support" name="1-я линия поддержки">
        <bpmn:flowNodeRef>Task_Reg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Req2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Issue</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_supply" name="Отдел снабжения">
        <bpmn:flowNodeRef>Task_Accept</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Avail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Order</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Intake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Disp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0944k2j</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_log" name="Логистика">
        <bpmn:flowNodeRef>Task_Deliver</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:task id="Task_Create" name="Создать заявку (почта / телефон)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Reg" name="Зарегистрировать обращение (Система №1), выдать номер">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Req2" name="Создать заявку на оборудование (Система №2)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Accept" name="Принять заявку (Система №2)">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Check" name="Проверить наличие (Система №3)">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Avail" name="Есть в наличии?">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Order" name="Создать заявку на закупку (поставщику)">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Intake" name="Принять оборудование (Система №3)">
      <bpmn:incoming>Flow_1eysict</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Merge" name="">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Disp" name="Вызвать логистику, передать ТП">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Issue" name="Выдать и закрыть заявки (Системы №1 и №2)">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Recv" name="Получить оборудование">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Rate" name="Оценить сервис (опционально)">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_User" name="Заявка закрыта">
      <bpmn:incoming>f16</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="Start_Need" targetRef="Task_Create" />
    <bpmn:sequenceFlow id="f2" sourceRef="Task_Create" targetRef="Task_Reg" />
    <bpmn:sequenceFlow id="f3" sourceRef="Task_Reg" targetRef="Task_Req2" />
    <bpmn:sequenceFlow id="f4" sourceRef="Task_Req2" targetRef="Task_Accept" />
    <bpmn:sequenceFlow id="f5" sourceRef="Task_Accept" targetRef="Task_Check" />
    <bpmn:sequenceFlow id="f6" sourceRef="Task_Check" targetRef="GW_Avail" />
    <bpmn:sequenceFlow id="f7" name="да (в наличии)" sourceRef="GW_Avail" targetRef="GW_Merge" />
    <bpmn:sequenceFlow id="f8" name="нет" sourceRef="GW_Avail" targetRef="Task_Order" />
    <bpmn:sequenceFlow id="f9" sourceRef="Task_Order" targetRef="Event_0944k2j" />
    <bpmn:sequenceFlow id="f10" sourceRef="Task_Intake" targetRef="GW_Merge" />
    <bpmn:sequenceFlow id="f11" sourceRef="GW_Merge" targetRef="Task_Disp" />
    <bpmn:sequenceFlow id="f12" sourceRef="Task_Disp" targetRef="Task_Deliver" />
    <bpmn:sequenceFlow id="f13" sourceRef="Task_Deliver" targetRef="Task_Issue" />
    <bpmn:sequenceFlow id="f14" sourceRef="Task_Issue" targetRef="Task_Recv" />
    <bpmn:sequenceFlow id="f15" sourceRef="Task_Recv" targetRef="Task_Rate" />
    <bpmn:sequenceFlow id="f16" sourceRef="Task_Rate" targetRef="End_User" />
    <bpmn:startEvent id="Start_Need" name="Возникла потребность">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Deliver" name="Доставить оборудование в ТП">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Event_0944k2j" name="Получена поставка оборудования">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>Flow_1eysict</bpmn:outgoing>
      <bpmn:messageEventDefinition id="Event_0944k2j_med" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_1eysict" sourceRef="Event_0944k2j" targetRef="Task_Intake" />
  </bpmn:process>
  <bpmn:process id="Proc_Sup" isExecutable="false">
    <bpmn:startEvent id="Start_Ord" name="Получен заказ">
      <bpmn:outgoing>fs1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="Start_Ord_med" />
    </bpmn:startEvent>
    <bpmn:task id="Task_SupDel" name="Привезти оборудование">
      <bpmn:incoming>fs1</bpmn:incoming>
      <bpmn:outgoing>fs2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Sup" name="">
      <bpmn:incoming>fs2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="fs1" sourceRef="Start_Ord" targetRef="Task_SupDel" />
    <bpmn:sequenceFlow id="fs2" sourceRef="Task_SupDel" targetRef="End_Sup" />
  </bpmn:process>
